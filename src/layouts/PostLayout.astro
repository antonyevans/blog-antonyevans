---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getPostUrl, slugify } from '../lib/content';
import { SITE_AUTHOR, SITE_NAME, getSocialImageForPost, toAbsoluteUrl } from '../lib/site';

interface Props {
  post: CollectionEntry<'blog'>;
  title: string;
  description: string;
  dek?: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  canonical: string;
  relatedPosts?: CollectionEntry<'blog'>[];
}

const { post, title, description, dek, pubDate, updatedDate, category, tags, canonical, relatedPosts = [] } = Astro.props;
const image = getSocialImageForPost(post);
const canonicalUrl = toAbsoluteUrl(canonical);
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  author: {
    '@type': 'Person',
    name: SITE_AUTHOR,
  },
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate || pubDate).toISOString(),
  mainEntityOfPage: canonicalUrl,
  image,
  publisher: {
    '@type': 'Person',
    name: SITE_NAME,
  },
};
---

<Layout
  title={`${title} | ${SITE_NAME}`}
  description={description}
  canonical={canonical}
  ogType="article"
  ogImage={image}
  publishedTime={pubDate}
  modifiedTime={updatedDate || pubDate}
  schema={schema}>
  <SiteHeader />
  <main class="container post-main">
    <article class="surface prose">
      <header>
        <p class="meta">
          <a class="chip" href={`/blog/category/${category}/1/`}>{category}</a>
          <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString('en-US', { dateStyle: 'long' })}</time>
          {updatedDate && <span>Updated {updatedDate.toLocaleDateString('en-US', { dateStyle: 'medium' })}</span>}
        </p>
        <h1>{title}</h1>
        {dek && <p class="dek">{dek}</p>}
      </header>
      <slot />
      <footer class="tags">
        {tags.map((tag) => (
          <a class="chip" href={`/blog/tag/${slugify(tag)}/1/`}>#{tag}</a>
        ))}
      </footer>
    </article>
    {relatedPosts.length > 0 && (
      <aside class="surface related">
        <h2>Related posts</h2>
        <ul>
          {relatedPosts.map((relatedPost) => (
            <li>
              <a href={getPostUrl(relatedPost)}>{relatedPost.data.title}</a>
              <span>{relatedPost.data.category}</span>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </main>
  <SiteFooter />
</Layout>

<style>
  .post-main { padding: 2rem 0; }
  .prose { max-width: 52rem; margin: 0 auto; padding: 1.6rem; }
  .meta {
    margin: 0;
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    font-size: 0.9rem;
  }

  h1 { margin: 0.85rem 0 0.6rem; font-size: clamp(2rem, 5vw, 3rem); }
  .dek { color: var(--muted); margin: 0 0 1rem; }
  .tags {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }
  .related {
    max-width: 52rem;
    margin: 1rem auto 0;
    padding: 1.4rem 1.6rem;
  }
  .related h2 { margin-top: 0; }
  .related ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .related li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--line);
    padding-top: 0.75rem;
  }
  .related li:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .related span {
    color: var(--muted);
    text-transform: capitalize;
    white-space: nowrap;
  }

  :global(.prose p) { margin: 0.9rem 0; }
  :global(.prose h2) { margin-top: 1.6rem; }
  :global(.prose code) {
    background: color-mix(in oklab, var(--accent-soft) 65%, var(--bg) 35%);
    border-radius: 0.3rem;
    padding: 0.1rem 0.35rem;
  }
  :global(.prose img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.25rem auto;
  }
</style>
